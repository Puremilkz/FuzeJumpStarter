{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixpacksDependencies": ["nodejs_20"]
        },
        "install": {
          "commands": "npm install",
          "dependsOn": ["setup"]
        },
        "build": {
          "commands": "echo 'no build needed'",
          "dependsOn": ["install"]
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "node server.js"
  }
}
