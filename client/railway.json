{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "install": {
          "commands": "npm install"
        },
        "build": {
          "commands": "npm run build"
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1
  }
}
